# ==========================================
# Core App Configuration
# ==========================================
# Database Connection (Default uses local SQLite warehouse)
DATABASE_URL="sqlite:///data/warehouse/hospital_dw.db"

# Streamlit App RBAC Passwords (override defaults)
RBAC_CLINICIAN_PASSWORD="your-strong-clinician-password"
RBAC_ANALYST_PASSWORD="your-strong-analyst-password"
RBAC_AUTH_SECRET="long-random-string-for-session-hmac"

# Data Pipeline Settings
MATRIX_SAMPLE=0     # Set to an integer (e.g. 1000) for fast dev testing
CHAMPION_SAMPLE=0
SKIP_TUNING=1       # 1 to reuse models/hyperparams.yaml, 0 to tune

# Redis Cache (Optional)
REDIS_URL="redis://localhost:6379/0"

# External APIs
FRED_API_KEY="your-fred-api-key"

# ==========================================
# Local LLM Providers (Ollama)
# ==========================================
OLLAMA_URL="http://localhost:11434"
OLLAMA_PRIMARY="deepseek-r1:latest"
OLLAMA_FALLBACK="llama3:latest"

# ==========================================
# Third-Party LLM Providers (Cloud APIs)
# ==========================================

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_API_BASE="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Google Gemini
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-1.5-pro"

# Groq (Fast Inference)
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama3-70b-8192"

# DeepSeek / Together AI / Mistral
DEEPSEEK_API_KEY="your-deepseek-api-key"
TOGETHER_API_KEY="your-together-api-key"
MISTRAL_API_KEY="your-mistral-api-key"

# Generic Custom OpenAI-Compatible Endpoint (e.g. vLLM, LM Studio, local proxies)
CUSTOM_LLM_BASE_URL="http://localhost:8000/v1"
CUSTOM_LLM_API_KEY="not-needed"
CUSTOM_LLM_MODEL="your-custom-model"
