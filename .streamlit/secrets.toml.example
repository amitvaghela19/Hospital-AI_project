# Copy to Streamlit Cloud → App settings → Secrets (or local `.streamlit/secrets.toml`).
# Do NOT commit real secrets to GitHub. This file is an example only.

# --- Optional RBAC overrides (Streamlit Cloud + local) ---
# If omitted, demo defaults apply everywhere: Clinician = baguvix, Analyst = aezakmi.
# RBAC_CLINICIAN_PASSWORD = "choose-a-strong-password"
# RBAC_ANALYST_PASSWORD = "choose-a-strong-password"
# RBAC_AUTH_SECRET = "long-random-string-for-session-signatures"

# --- Security note ---
# Viewer, Clinician, and Analyst modes are READ-ONLY for patient data.
# Passwords grant access to view more data (IDs, SQL SELECT, scoring) — never to edit/delete records.

# --- Optional LLM (chat formatting) ---
# End users can also configure a custom OpenAI-compatible provider in the sidebar.
# OLLAMA_URL = "http://127.0.0.1:11434"
# OLLAMA_PRIMARY = "deepseek-r1:latest"
# OLLAMA_FALLBACK = "llama3:latest"

# Cloud tunnel example:
# OLLAMA_URL = "https://your-tunnel.example.com"
